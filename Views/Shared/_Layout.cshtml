<!DOCTYPE html>
<html lang="bs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SistemZaZaposlenike</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    }
    <!-- NAVBAR -->
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark shadow-sm fixed-top">
            <div class="container">
                <a class="navbar-brand fw-semibold" asp-controller="Home" asp-action="Index">
                    SistemZaZaposlenike
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">

                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Home" ? "active fw-semibold" : "")" asp-controller="Home" asp-action="Index">Početna</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Zaposlenici" ? "active fw-semibold" : "")" asp-controller="Zaposlenici" asp-action="Index">Zaposlenici</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Odjeli" ? "active fw-semibold" : "")" asp-controller="Odjeli" asp-action="Index">Odjeli</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Projekti" ? "active fw-semibold" : "")" asp-controller="Projekti" asp-action="Index">Projekti</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Izvjestaj" ? "active fw-semibold text-success" : "text-success fw-semibold")" asp-controller="Izvjestaj" asp-action="Index">Izvještaj</a>
                        </li>

                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- CONTENT -->
    <div class="container">

        <!-- SUCCESS MESSAGE -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <main role="main" class="pb-3 mt-3">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER -->
    <footer class="border-top footer text-muted">
        <div class="container py-3">
            &copy; 2026 - Sistem za upravljanje zaposlenicima
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>