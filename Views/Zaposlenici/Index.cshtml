<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Zaposlenici</h2>

    <a asp-action="Create" class="btn btn-primary">
        + Dodaj zaposlenika
    </a>
</div>

<form method="get" class="mb-3">
    <div class="row g-2 align-items-end">

        <div class="col-md-4">
            <label class="form-label small text-muted">Filter po odjelu</label>

            <select name="odjelId" class="form-select" onchange="this.form.submit()">
                <option value="">-- Svi odjeli --</option>

                @foreach (var odjel in ViewBag.Odjeli)
                {
                    <option value="@odjel.Value"
                            selected="@(odjel.Value == ViewBag.OdabraniOdjelId?.ToString())">
                        @odjel.Text
                    </option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <a href="/Zaposlenici" class="btn btn-outline-secondary w-100">
                Reset
            </a>
        </div>

    </div>
</form>

<div class="card shadow-sm">
    <div class="card-body p-0">

        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Ime</th>
                    <th>Prezime</th>
                    <th>Email</th>
                    <th>Plata</th>
                    <th>Odjel</th>
                    <th class="text-end">Akcije</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Ime</td>
                        <td>@item.Prezime</td>
                        <td>@item.Email</td>

                        <td>
                            <span class="fw-semibold text-success">
                                @String.Format("{0:N0}", item.PlataMonthly) KM
                            </span>
                        </td>

                        <td>
                            @{
                                var odjelClass = item.Odjel?.Naziv switch
                                {
                                    "IT" => "badge-it",
                                    "HR" => "badge-hr",
                                    "Finance" => "badge-finance",
                                    _ => "bg-secondary"
                                };
                            }

                            <span class="badge badge-odjel @odjelClass">
                                @item.Odjel?.Naziv
                            </span>
                        </td>

                        <td class="text-end">
                            <div class="table-actions justify-content-end">

                                <a asp-action="Edit" asp-route-id="@item.ZaposlenikID"
                                   class="btn btn-sm btn-outline-primary">
                                    Edit
                                </a>

                                <a asp-action="Details" asp-route-id="@item.ZaposlenikID"
                                   class="btn btn-sm btn-outline-info">
                                    Details
                                </a>

                                <a asp-action="Delete" asp-route-id="@item.ZaposlenikID"
                                   class="btn btn-sm btn-outline-danger">
                                    Delete
                                </a>

                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>