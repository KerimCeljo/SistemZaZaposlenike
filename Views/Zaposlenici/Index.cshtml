<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Zaposlenici</h2>

    <a asp-action="Create" class="btn btn-primary">
        + Dodaj zaposlenika
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">

        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Ime</th>
                    <th>Prezime</th>
                    <th>Email</th>
                    <th>Plata</th>
                    <th>Odjel</th>
                    <th class="text-end">Akcije</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Ime</td>
                        <td>@item.Prezime</td>
                        <td>@item.Email</td>

                        <td>
                            <span class="fw-semibold text-success">
                                @String.Format("{0:N0}", item.PlataMonthly) KM
                            </span>
                        </td>

                        <td>
                            @{
                                var odjelClass = item.Odjel?.Naziv switch
                                {
                                    "IT" => "badge-it",
                                    "HR" => "badge-hr",
                                    "Finance" => "badge-finance",
                                    _ => "bg-secondary"
                                };
                            }

                            <span class="badge badge-odjel @odjelClass">
                                @item.Odjel?.Naziv
                            </span>
                        </td>

                        <td class="text-end">
                            <div class="table-actions justify-content-end">

                                <a asp-action="Edit" asp-route-id="@item.ZaposlenikID"
                                   class="btn btn-sm btn-outline-primary">
                                    Edit
                                </a>

                                <a asp-action="Details" asp-route-id="@item.ZaposlenikID"
                                   class="btn btn-sm btn-outline-info">
                                    Details
                                </a>

                                <a asp-action="Delete" asp-route-id="@item.ZaposlenikID"
                                   class="btn btn-sm btn-outline-danger">
                                    Delete
                                </a>

                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>