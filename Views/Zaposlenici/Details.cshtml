@model SistemZaZaposlenike.Models.Zaposlenik

@{
    ViewData["Title"] = "Detalji zaposlenika";
}

<h1>Detalji zaposlenika</h1>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Ime</dt>
            <dd class="col-sm-9">@Model.Ime</dd>

            <dt class="col-sm-3">Prezime</dt>
            <dd class="col-sm-9">@Model.Prezime</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Plata</dt>
            <dd class="col-sm-9">@Model.PlataMonthly.ToString("N2") BAM</dd>

            <dt class="col-sm-3">Datum zaposlenja</dt>
            <dd class="col-sm-9">@Model.DatumZaposlenja.ToString("dd.MM.yyyy")</dd>

            <dt class="col-sm-3">Odjel</dt>
            <dd class="col-sm-9">@Model.Odjel?.Naziv</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.ZaposlenikID" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Nazad</a>
</div>

<hr />

<h4>Konverzija plate</h4>

<form asp-action="Details" method="get" class="row g-3">
    <input type="hidden" name="id" value="@Model.ZaposlenikID" />

    <div class="col-md-4">
        <label class="form-label">Odaberi valutu</label>
        <select name="valuta" class="form-select">
            <option value="">-- Odaberi valutu --</option>
            <option value="EUR" selected="@(ViewBag.OdabranaValuta == "EUR")">EUR</option>
            <option value="USD" selected="@(ViewBag.OdabranaValuta == "USD")">USD</option>
            <option value="GBP" selected="@(ViewBag.OdabranaValuta == "GBP")">GBP</option>
            <option value="CHF" selected="@(ViewBag.OdabranaValuta == "CHF")">CHF</option>
        </select>
    </div>

    <div class="col-md-4 d-flex align-items-end">
        <button type="submit" class="btn btn-primary">Konvertuj</button>
    </div>
</form>

@if (ViewBag.ValutaError != null)
{
    <div class="alert alert-warning mt-3">
        @ViewBag.ValutaError
    </div>
}
else if (ViewBag.OdabranaValuta != null && ViewBag.KonvertovaniIznos != null)
{
    <div class="alert alert-info mt-3">
        Konvertovana plata:
        <strong>@ViewBag.KonvertovaniIznos @ViewBag.OdabranaValuta</strong>
    </div>
}