@model SistemZaZaposlenike.Models.Zaposlenik

@{
    ViewData["Title"] = "Detalji zaposlenika";
}

<h1>Detalji zaposlenika</h1>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Ime</dt>
            <dd class="col-sm-9">@Model.Ime</dd>

            <dt class="col-sm-3">Prezime</dt>
            <dd class="col-sm-9">@Model.Prezime</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Plata</dt>
            <dd class="col-sm-9">@Model.PlataMonthly.ToString("N2") BAM</dd>

            <dt class="col-sm-3">Datum zaposlenja</dt>
            <dd class="col-sm-9">@Model.DatumZaposlenja.ToString("dd.MM.yyyy")</dd>

            <dt class="col-sm-3">Odjel</dt>
            <dd class="col-sm-9">@Model.Odjel?.Naziv</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.ZaposlenikID" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Nazad</a>
</div>