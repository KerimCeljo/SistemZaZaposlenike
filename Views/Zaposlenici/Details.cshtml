@model SistemZaZaposlenike.Models.Zaposlenik

@{
    ViewData["Title"] = "Detalji zaposlenika";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Detalji zaposlenika</h2>
        <p class="text-muted mb-0">Pregled osnovnih podataka i konverzija mjesečne plate.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.ZaposlenikID" class="btn btn-warning">
            Uredi
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            Nazad na listu
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body p-4">
                <h5 class="card-title mb-4">Osnovni podaci</h5>

                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Ime</dt>
                    <dd class="col-sm-8 fw-semibold">@Model.Ime</dd>

                    <dt class="col-sm-4 text-muted">Prezime</dt>
                    <dd class="col-sm-8 fw-semibold">@Model.Prezime</dd>

                    <dt class="col-sm-4 text-muted">Email</dt>
                    <dd class="col-sm-8">@Model.Email</dd>

                    <dt class="col-sm-4 text-muted">Mjesečna plata</dt>
                    <dd class="col-sm-8 text-success fw-bold">
                        @Model.PlataMonthly.ToString("N2") BAM
                    </dd>

                    <dt class="col-sm-4 text-muted">Datum zaposlenja</dt>
                    <dd class="col-sm-8">@Model.DatumZaposlenja.ToString("dd.MM.yyyy")</dd>

                    <dt class="col-sm-4 text-muted">Odjel</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-secondary px-3 py-2">@Model.Odjel?.Naziv</span>
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body p-4">
                <h5 class="card-title mb-4">Konverzija plate</h5>

                <form id="currencyForm" asp-action="Details" method="get" class="row g-3">
                    <input type="hidden" name="id" value="@Model.ZaposlenikID" />

                    <div class="col-12">
                        <label class="form-label fw-semibold">Odaberi valutu</label>
                        <select name="valuta" class="form-select">
                            <option value="">-- Odaberi valutu --</option>
                            <option value="EUR" selected="@(ViewBag.OdabranaValuta == "EUR")">EUR</option>
                            <option value="USD" selected="@(ViewBag.OdabranaValuta == "USD")">USD</option>
                            <option value="GBP" selected="@(ViewBag.OdabranaValuta == "GBP")">GBP</option>
                            <option value="CHF" selected="@(ViewBag.OdabranaValuta == "CHF")">CHF</option>
                        </select>
                    </div>

                    <div class="col-12">
                        <button id="convertBtn" type="submit" class="btn btn-primary">
                            Konvertuj platu
                        </button>
                    </div>
                </form>

                @if (ViewBag.ValutaError != null)
                {
                    <div class="alert alert-warning mt-4 mb-0">
                        @ViewBag.ValutaError
                    </div>
                }
                else if (ViewBag.OdabranaValuta != null && ViewBag.KonvertovaniIznos != null)
                {
                    <div class="alert alert-info mt-4 mb-0">
                        <div class="small text-muted mb-1">Rezultat konverzije</div>
                        <div class="fs-5 fw-bold">
                            @ViewBag.KonvertovaniIznos @ViewBag.OdabranaValuta
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const form = document.getElementById("currencyForm");
        const btn = document.getElementById("convertBtn");

        if (form && btn) {
            form.addEventListener("submit", function () {
                btn.disabled = true;
                btn.textContent = "Konvertujem...";
            });
        }
    </script>
}