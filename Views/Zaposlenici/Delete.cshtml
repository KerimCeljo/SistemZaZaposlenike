@model SistemZaZaposlenike.Models.Zaposlenik

@{
    ViewData["Title"] = "Obriši zaposlenika";
}

<h1>Obriši zaposlenika</h1>

<div class="alert alert-warning">
    Jesi li siguran da želiš obrisati ovog zaposlenika?
</div>

<div class="card mb-3">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Ime</dt>
            <dd class="col-sm-9">@Model.Ime</dd>

            <dt class="col-sm-3">Prezime</dt>
            <dd class="col-sm-9">@Model.Prezime</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Plata</dt>
            <dd class="col-sm-9">@Model.PlataMonthly.ToString("N2")</dd>

            <dt class="col-sm-3">Odjel</dt>
            <dd class="col-sm-9">@Model.Odjel?.Naziv</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="ZaposlenikID" />
    <button type="submit" class="btn btn-danger">Obriši</button>
    <a asp-action="Index" class="btn btn-secondary">Nazad</a>
</form>