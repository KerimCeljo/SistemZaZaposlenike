@model SistemZaZaposlenike.Models.Projekat

@{
    ViewData["Title"] = "Detalji projekta";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Detalji projekta</h2>
        <p class="text-muted mb-0">Pregled osnovnih informacija i angažovanih zaposlenika.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        Nazad na listu
    </a>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body p-4">
        <h5 class="card-title mb-4">Osnovni podaci</h5>

        <dl class="row mb-0">
            <dt class="col-sm-4 text-muted">Naziv</dt>
            <dd class="col-sm-8 fw-semibold">@Model.Naziv</dd>

            <dt class="col-sm-4 text-muted">Budžet</dt>
            <dd class="col-sm-8 text-success fw-bold">
                @(Model.BudzetUSD?.ToString("N2") ?? "-") USD
            </dd>

            <dt class="col-sm-4 text-muted">Datum početka</dt>
            <dd class="col-sm-8">@(Model.DatumPocetak?.ToString("dd.MM.yyyy") ?? "-")</dd>

            <dt class="col-sm-4 text-muted">Datum kraja</dt>
            <dd class="col-sm-8">@(Model.DatumKraj?.ToString("dd.MM.yyyy") ?? "-")</dd>

            <dt class="col-sm-4 text-muted">Broj angažovanih zaposlenika</dt>
            <dd class="col-sm-8">
                <span class="badge bg-dark px-3 py-2">
                    @Model.ZaposlenikProjekti.Count
                </span>
            </dd>
        </dl>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="p-4 pb-2">
            <h5 class="mb-0">Angažovani zaposlenici</h5>
        </div>

        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Ime</th>
                    <th>Prezime</th>
                    <th>Email</th>
                    <th>Uloga</th>
                    <th class="text-center">Sati / tjedan</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var stavka in Model.ZaposlenikProjekti)
                {
                    <tr>
                        <td class="fw-semibold">@stavka.Zaposlenik?.Ime</td>
                        <td>@stavka.Zaposlenik?.Prezime</td>
                        <td>@stavka.Zaposlenik?.Email</td>
                        <td>@stavka.Uloga</td>
                        <td class="text-center">
                            <span class="badge bg-primary">
                                @stavka.SatiNaTjednu
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>