@model SistemZaZaposlenike.Models.Projekat

@{
    ViewData["Title"] = "Detalji projekta";
}

<h1>Detalji projekta</h1>

<div class="card mb-4">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Naziv</dt>
            <dd class="col-sm-9">@Model.Naziv</dd>

            <dt class="col-sm-3">Budžet (USD)</dt>
            <dd class="col-sm-9">@(Model.BudzetUSD?.ToString("N2") ?? "-")</dd>

            <dt class="col-sm-3">Datum početka</dt>
            <dd class="col-sm-9">@(Model.DatumPocetak?.ToString("dd.MM.yyyy") ?? "-")</dd>

            <dt class="col-sm-3">Datum kraja</dt>
            <dd class="col-sm-9">@(Model.DatumKraj?.ToString("dd.MM.yyyy") ?? "-")</dd>
        </dl>
    </div>
</div>

<h3>Angažovani zaposlenici</h3>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Ime</th>
            <th>Prezime</th>
            <th>Email</th>
            <th>Uloga</th>
            <th>Sati na tjednu</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var stavka in Model.ZaposlenikProjekti)
        {
            <tr>
                <td>@stavka.Zaposlenik?.Ime</td>
                <td>@stavka.Zaposlenik?.Prezime</td>
                <td>@stavka.Zaposlenik?.Email</td>
                <td>@stavka.Uloga</td>
                <td>@stavka.SatiNaTjednu</td>
            </tr>
        }
    </tbody>
</table>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Nazad</a>
</div>